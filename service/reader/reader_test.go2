package reader

import (
	"fmt"
	"os"
	"path/filepath"
	"reflect"
	"testing"

	"github.com/hashicorp/hcl/v2"
)

func CreateTestFile(t *testing.T) string {
	tmpDir := t.TempDir()
	tmpFile := fmt.Sprintf("%s.hcl", "test-hcl")
	tmpFilePath := filepath.Join(tmpDir, tmpFile)

	f, err := os.Create(tmpFilePath)
	if err != nil {
		t.Fatal(err.Error())
	}

	defer f.Close()

	out := []byte(`workflow "workflow_1" {
	name = "Workflow 1"
}`,
	)

	_, err = f.Write(out)
	if err != nil {
		t.Fatal(err.Error())
	}

	return tmpFilePath
}

func TestReader(t *testing.T) {
	t.Run("reads a file into an hcl.Body", func(t *testing.T) {
		tmpFile := CreateTestFile(t)

		ar := NewReader("", "", false)
		body, err := ar.ReadHclFile(tmpFile)
		if err != nil {
			t.Fatal(err.Error())
		}

		typeof := reflect.TypeOf((*hcl.Body)(nil)).Elem()

		if !reflect.TypeOf(body).Implements(typeof) {
			t.Fatal(err.Error())
		}
	})

	t.Run("cannot read a non existing file", func(t *testing.T) {
		tmpDir := t.TempDir()
		tmpFile := fmt.Sprintf("%s.hcl", "test-hcl")
		atosReader := NewReader(tmpDir, tmpFile, false)

		err := atosReader.Do()
		if err == nil {
			t.FailNow()
		}
	})
}
